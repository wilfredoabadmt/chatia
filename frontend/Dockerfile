# syntax=docker/dockerfile:1
FROM node:20-alpine AS builder

RUN apk add --no-cache python3 make g++

WORKDIR /app
COPY package*.json ./
RUN --mount=type=cache,target=/root/.npm \
    npm install --legacy-peer-deps

COPY . .

ARG REACT_APP_BACKEND_URL
ARG REACT_APP_NAME_SYSTEM
ARG REACT_APP_COMPANY_NAME
ARG REACT_APP_NUMBER_SUPPORT
ARG REACT_APP_HOURS_CLOSE_TICKETS_AUTO
ARG REACT_APP_PRIMARY_COLOR
ARG REACT_APP_PRIMARY_DARK
ARG REACT_APP_FACEBOOK_APP_ID
ARG REACT_APP_REQUIRE_BUSINESS_MANAGEMENT
ARG REACT_APP_FEATURE_KANBAN_V2
ARG REACT_APP_FEATURE_NOVA
ARG REACT_APP_FEATURE_COMPANY_SEARCH

ENV REACT_APP_BACKEND_URL=$REACT_APP_BACKEND_URL \
    REACT_APP_NAME_SYSTEM=$REACT_APP_NAME_SYSTEM \
    REACT_APP_COMPANY_NAME=$REACT_APP_COMPANY_NAME \
    REACT_APP_NUMBER_SUPPORT=$REACT_APP_NUMBER_SUPPORT \
    REACT_APP_HOURS_CLOSE_TICKETS_AUTO=$REACT_APP_HOURS_CLOSE_TICKETS_AUTO \
    REACT_APP_PRIMARY_COLOR=$REACT_APP_PRIMARY_COLOR \
    REACT_APP_PRIMARY_DARK=$REACT_APP_PRIMARY_DARK \
    REACT_APP_FACEBOOK_APP_ID=$REACT_APP_FACEBOOK_APP_ID \
    REACT_APP_REQUIRE_BUSINESS_MANAGEMENT=$REACT_APP_REQUIRE_BUSINESS_MANAGEMENT \
    REACT_APP_FEATURE_KANBAN_V2=$REACT_APP_FEATURE_KANBAN_V2 \
    REACT_APP_FEATURE_NOVA=$REACT_APP_FEATURE_NOVA \
    REACT_APP_FEATURE_COMPANY_SEARCH=$REACT_APP_FEATURE_COMPANY_SEARCH \
    NODE_OPTIONS=--max-old-space-size=1024 \
    GENERATE_SOURCEMAP=false

RUN npx craco build || { echo "Build falhou, tentando com menos memória..."; NODE_OPTIONS=--max-old-space-size=768 npx craco build; }

FROM nginx:alpine
COPY --from=builder /app/build /usr/share/nginx/html
COPY nginx.conf /etc/nginx/conf.d/default.conf
EXPOSE 80
CMD ["nginx", "-g", "daemon off;"]
